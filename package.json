{
  "name": "scamp",
  "version": "0.4.3",
  "description": "Local-first design tool. Draw, get real TSX + CSS.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Angie Hemans",
    "email": "angie@scampdesign.app"
  },
  "homepage": "https://github.com/angiehemans/scamp",
  "license": "BSL",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "patch-package && electron-rebuild -f -w node-pty",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:unit": "vitest run --dir test --exclude test/integration",
    "test:integration": "vitest run --dir test/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:nobuild": "playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "package": "npm run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@sentry/electron": "^7.13.0",
    "@tabler/icons-react": "^3.41.1",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "html-to-image": "^1.11.13",
    "htmlparser2": "^12.0.0",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.9",
    "react-colorful": "^5.7.0",
    "zundo": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.2.0",
    "patch-package": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
