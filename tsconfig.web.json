{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@lib/*": ["src/renderer/lib/*"],
      "@store/*": ["src/renderer/store/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/renderer/**/*",
    "src/shared/**/*",
    "test/**/*",
    "src/main/ipc/componentOps.ts",
    "src/main/ipc/snapshotOps.ts",
    "src/main/ipc/fileConflict.ts",
    "src/main/ipc/imageOps.ts",
    "src/main/ipc/pathContainment.ts",
    "src/main/watcher.ts",
    "src/main/ipc/pageOps.ts",
    "src/main/ipc/pageRename.ts",
    "src/main/ipc/terminalForeground.ts",
    "src/main/ipc/projectFormat.ts",
    "src/main/ipc/projectFormatCache.ts",
    "src/main/ipc/projectMigrate.ts",
    "src/main/ipc/projectScaffold.ts",
    "src/main/ipc/settings.ts",
    "src/main/ipc/settingsOps.ts",
    "src/main/ipc/themeOps.ts",
    "src/main/ipc/fileOps.ts",
    "src/main/ipc/exportOps.ts",
    "src/main/ipc/projectConfigOps.ts",
    "src/main/ipc/recentProjectsOps.ts",
    "src/main/devServer/portAlloc.ts",
    "src/main/devServer/readyDetector.ts",
    "src/main/pendingWrites.ts",
    "src/main/sentry.ts"
  ]
}
